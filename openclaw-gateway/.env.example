# Gemini Authentication (Required)
# Get these cookies from gemini.google.com after logging in
GEMINI_SECURE_1PSID=your_cookie_value_here
GEMINI_SECURE_1PSIDTS=your_cookie_value_here

# OR use a cookies JSON file
# GEMINI_COOKIES_JSON=/path/to/cookies.json

# Server Configuration
API_HOST=0.0.0.0
API_PORT=18789
API_WORKERS=4
LOG_LEVEL=INFO

# Security (Optional)
# Set a bearer token to require authentication
# API_BEARER_TOKEN=your_secret_token_here

# CORS Origins (comma-separated)
ALLOWED_ORIGINS=*

# File Size Limits (in MB)
MAX_FILE_SIZE_MB=100
MAX_IMAGE_SIZE_MB=50
MAX_URL_PARTS=8
REQUEST_TIMEOUT=300

# Feature Flags
ENABLE_URL_FETCH=true
ENABLE_IMAGE_GENERATION=true
ENABLE_VIDEO_GENERATION=true
ENABLE_AUDIO_GENERATION=true

# URL Allowlists (Optional, comma-separated)
# Leave empty to allow all URLs
# IMAGE_URL_ALLOWLIST=cdn.example.com,*.assets.example.com
# FILE_URL_ALLOWLIST=docs.example.com
